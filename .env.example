# =============================================================================
# ReAct Agent — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your API keys.
# At least ONE LLM provider API key is required.

# --- LLM Provider API Keys (provide at least one) ---
GEMINI_API_KEY=your_gemini_api_key_here


# --- Agent Configuration ---
# LLM provider to use: gemini, openai, or anthropic
LLM_PROVIDER=gemini

# Specific model name (leave empty to use provider default)
# Gemini default: gemini-2.0-flash
# OpenAI default: gpt-4o-mini
# Anthropic default: claude-sonnet-4-20250514
LLM_MODEL=

# Maximum number of reasoning steps before the agent stops
MAX_STEPS=10

# --- Tool Configuration ---
# Directory that the read_file tool is allowed to access
ALLOWED_READ_DIR=./
